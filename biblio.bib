@article{Bidone2019,
abstract = {Integrin conformational dynamics are critical to their receptor and signaling functions in many cellular processes, including spreading, adhesion, and migration. However, assessing integrin conformations is both experimentally and computationally challenging because of limitations in resolution and dynamic sampling. Thus, structural changes that underlie transitions between conformations are largely unknown. Here, focusing on integrin $\alpha$v$\beta$ 3 , we developed a modified form of the coarse-grained heterogeneous elastic network model (hENM), which allows sampling conformations at the onset of activation by formally separating local fluctuations from global motions. Both local fluctuations and global motions are extracted from all-atom molecular dynamics simulations of the full-length $\alpha$v$\beta$ 3 bent integrin conformer, but whereas the former are incorporated in the hENM as effective harmonic interactions between groups of residues, the latter emerge by systematically identifying and treating weak interactions between long-distance domains with flexible and anharmonic connections. The new hENM model allows integrins and single-point mutant integrins to explore various conformational states, including the initiation of separation between $\alpha$- and $\beta$-subunit cytoplasmic regions, headpiece extension, and legs opening.},
author = {Bidone, Tamara C. and Polley, Anirban and Jin, Jaehyeok and Driscoll, Tristan and Iwamoto, Daniel V. and Calderwood, David A. and Schwartz, Martin A. and Voth, Gregory A.},
doi = {10.1016/j.bpj.2019.02.011},
file = {:home/quimico/.local/share/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Bidone et al. - 2019 - Coarse-Grained Simulation of Full-Length Integrin Activation.pdf:pdf},
issn = {15420086},
journal = {Biophysical Journal},
number = {6},
pages = {1000--1010},
pmid = {30851876},
publisher = {Biophysical Society},
title = {{Coarse-Grained Simulation of Full-Length Integrin Activation}},
url = {https://doi.org/10.1016/j.bpj.2019.02.011},
volume = {116},
year = {2019}
}
