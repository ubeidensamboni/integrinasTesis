}
@article{Xiong2009,
abstract = {We determined the crystal structure of 1TM-$\alpha$V$\beta$3, which represents the complete unconstrained ectodomain plus short C-terminal transmembrane stretches of the $\alpha$V and $\beta$3 subunits. 1TM-$\alpha$V$\beta$3 is more compact and less active in solution when compared with $\Delta$TM-$\alpha$V$\beta$3, which lacks the short C-terminal stretches. The structure reveals a bent conformation and defines the $\alpha$-$\beta$ interface between IE2 (EGF-like 2) and the thigh domains. Modifying this interface by site-directed mutagenesis leads to robust integrin activation. Fluorescent lifetime imaging microscopy of inactive full-length $\alpha$V$\beta$3 on live cells yields a donor-membrane acceptor distance, which is consistent with the bent conformation and does not change in the activated integrin. These data are the first direct demonstration of conformational coupling of the integrin leg and head domains, identify the IE2-thigh interface as a critical steric barrier in integrin activation, and suggest that inside-out activation in intact cells may involve conformational changes other than the postulated switch to a genu-linear state. {\textcopyright} 2009 Xiong et al.},
author = {Xiong, Jian Ping and Mahalingham, Bhuvaneshwari and Alonso, Jose Luis and Borrelli, Laura Ann and Rui, Xianliang and Anand, Saurabh and Hyman, Bradley T. and Rysiok, Thomas and M{\"{u}}ller-Pompalla, Dirk and Goodman, Simon L. and Arnaout, M. Amin},
doi = {10.1083/jcb.200905085},
file = {:home/quimico/.local/share/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Xiong et al. - 2009 - Crystal structure of the complete integrin $\alpha$V$\beta$3 ectodomain plus an $\alpha$$\beta$ transmembrane fragment.pdf:pdf},
issn = {00219525},
journal = {Journal of Cell Biology},
number = {4},
pages = {589--600},
pmid = {19704023},
title = {{Crystal structure of the complete integrin $\alpha$V$\beta$3 ectodomain plus an $\alpha$/$\beta$ transmembrane fragment}},
volume = {186},
year = {2009}
}
