issn = {16737342},
journal = {Frontiers of Medicine in China},
keywords = {cell adhesion,integrin,kindling,nanodisc,signal transduction,talin,transmembrane domain},
number = {1},
pages = {6--16},
pmid = {24477625},
title = {{Talin and kindlin: The one-two punch in integrin activation}},
volume = {8},
year = {2014}
}
@article{Fox1957,
abstract = {A study has been made of the force-area and potential-area relations of monolayers of CF3(CH2)16COOH and CF3(CH 2)17 NH2 spread on water at various pH values. The curves obtained for these substances are compared with those for stearic acid and octadecylamine obtained on the same substrates. In contrast to the latter, the fluorinated compounds form films which do not support high pressures, and whose molecular areas at closest packing are, under some conditions, too large to be accounted for by the extra bulk of the -CF3 group. This behavior is attributed to intermolecular repulsions of the strong dipoles associated with the -CF3 group attached to the hydrocarbon chain. The surface potentials of films of the terminally fluorinated octadecyl derivatives are higher than any yet reported.},
