@article{Adair2002,
abstract = {Integrins are a large family of heterodimeric transmembrane signaling proteins that affect diverse biological processes such as development, angiogenesis, wound healing, neoplastic transformation, and thrombosis. We report here the three-dimensional structure at 20-{\AA} resolution of the unliganded, low-affinity state of the human platelet integrin $\alpha$11b$\beta$33 derived by electron cryomicroscopy and single particle image reconstruction. The large ectodomain and small cytoplasmic domains are connected by a rod of density that we interpret as two parallel transmembrane $\alpha$-helices. The docking of the x-ray structure of the $\alpha$$\nu$$\beta$3 ectodomain into the electron cryomicroscopy map of $\alpha$111b$\beta$3 requires hinge movements at linker regions between domains in the crystal structure. Comparison of the putative high- and low-affinity conformations reveals dramatic conformational changes associated with integrin activation.},
