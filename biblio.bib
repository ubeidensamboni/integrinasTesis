doi = {10.1073/pnas.0438060100},
file = {:home/quimico/.local/share/data/Mendeley Ltd./Mendeley Desktop/Downloaded/Luo, Springer, Takagi - 2003 - Stabilizing the open conformation of the integrin headpiece with a glycan wedge increases affinity for li.pdf:pdf},
